# ==================== 数据库配置 ====================
# SQLite 数据库文件路径（相对于 backend 目录）
DATABASE_PATH=casegen.db

# ==================== LLM 配置 ====================
# 默认 LLM 模型（可在前端设置页覆盖）
DEFAULT_LLM_MODEL=openai/gpt-4o
# OpenAI API Key
OPENAI_API_KEY=
# Anthropic API Key
ANTHROPIC_API_KEY=
# LLM API Base URL（可选，用于代理）
LLM_API_BASE=

# ==================== 飞书通知 ====================
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=

# ==================== 应用配置 ====================
# 后端端口
BACKEND_PORT=8000
# 前端端口
FRONTEND_PORT=5173
# 上传文件大小限制（MB）
MAX_UPLOAD_SIZE_MB=50
# 日志级别
LOG_LEVEL=INFO
